{
  "manifest_version": 3,
  "name": "ETHZ Auto-Login",
  "version": "1.1.0",
  "description": "Automatically logs you into ETHZ websites using stored credentials",
  "permissions": ["storage"],
  "host_permissions": ["*://*.ethz.ch/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.ethz.ch/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
